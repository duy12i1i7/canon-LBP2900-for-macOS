+	for (unsigned polls = 0; ; ++polls) {
 	  status = lbp2900_get_status(state->ops);
 	  if (status->page_received == status->page_decoding)
 	    break;
+	  if (polls >= CAPT_WAIT_POLLS_PAGE) {
