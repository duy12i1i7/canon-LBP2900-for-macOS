# Patch: captdriver (master) -> Canon LBP2900 working on macOS
# Apply from the captdriver source root:  patch -p1 < lbp2900-macos.patch
# (1) status-strategy hang fix  (2) PAGE: progress  (3) STATE: out-of-paper
# (4) 100ms polling (near-continuous)  (5) bounded wait timeouts (never hang)
# (6) blink printer LED on out-of-paper
#
--- a/src/std.h	2022-10-13 20:10:28
+++ b/src/std.h	2026-07-07 17:41:11
@@ -31,3 +31,10 @@
 	((type *) ((char *) ptr - offsetof(type, member)))
 
 #define debug true
+
+/* Status-poll interval for the printer wait loops (microseconds). The stock
+ * driver polled once per second (sleep(1)), which idles the print engine for up
+ * to ~1 s at every handshake and makes multi-page jobs stall between sheets.
+ * Polling at 100 ms keeps the printer fed and prints near-continuously, without
+ * changing the CAPT command sequence. usleep() needs <unistd.h>. */
+#define CAPT_POLL_US 100000
--- a/src/capt-status.c	2022-10-13 20:10:28
+++ b/src/capt-status.c	2026-07-07 17:41:11
@@ -122,17 +122,17 @@
 void capt_wait_ready(void)
 {
 	while (FLAG(capt_get_status(), CAPT_FL_BUSY))
-		sleep(1);
+		usleep(CAPT_POLL_US);
 }
 
 void capt_wait_xready(void)
 {
 	while (FLAG(capt_get_xstatus(), CAPT_FL_BUSY))
-		sleep(1);
+		usleep(CAPT_POLL_US);
 }
 
 void capt_wait_xready_only(void)
 {
        while (FLAG(capt_get_xstatus_only(), CAPT_FL_BUSY))
-               sleep(1);
+               usleep(CAPT_POLL_US);
 }
--- a/src/prn_lbp2900.c	2022-10-13 20:10:28
+++ b/src/prn_lbp2900.c	2026-07-07 19:14:16
@@ -36,6 +36,15 @@
 
