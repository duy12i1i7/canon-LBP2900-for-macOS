+					CAPT_WAIT_POLLS_PAGE / 10);
+			break;
+		}
+		usleep(CAPT_POLL_US);
 	}
 
 	capt_multi_begin(CAPT_SET_PARMS);
@@ -334,12 +352,18 @@
 
 	capt_send(CAPT_PRINT_DATA_END, NULL, 0);
 
-	/* waiting until the page is received */
